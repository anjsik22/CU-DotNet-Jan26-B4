@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<style>
:root{
    --primary: #ff6b6b;
    --primary-dark: #c31432;
}
.login-global-bg {
    /* fallback global class in case body styles are overridden */
    background: linear-gradient(135deg, #c31432 0%, #ff6b6b 40%, #fff0f6 100%);
}
html, body {
    height: 100%;
    margin: 0; /* remove white page margin */
    background: linear-gradient(135deg, #c31432 0%, #ff6b6b 40%, #fff0f6 100%);
}

.login-page {
    /* leave room for the site footer without forcing a scrollbar */
    min-height: calc(100vh - 120px);
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 40px;
}

.login-card {
    display: flex;
    width: 900px;
    max-width: calc(100% - 80px);
    height: 520px;
    border-radius: 16px; /* outer rounded container */
    overflow: hidden;
    /* keep outer container transparent so page gradient shows through */
    background: transparent;
    box-shadow: 0 20px 40px rgba(18,22,32,0.12);
    position: relative;
}

/* LEFT SIDE - warm gradient */
.login-visual {
    flex: 1;
    padding: 48px;
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    background: linear-gradient(135deg, #c31432 0%, #ff6b6b 100%);
    position: relative;
}
.login-visual::before{
    content: '';
    position: absolute;
    right: -80px;
    top: -40px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.08), rgba(255,255,255,0));
    transform: rotate(15deg);
    border-radius: 50%;
}

/* RIGHT SIDE - clean white with floating card */
.login-form {
    flex: 1;
    padding: 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* keep panel transparent so the page ink shows through; floating card provides contrast */
    background:white;
    position: relative;
}

/* inner floating card */
.login-form .card {
    width: 340px;
    margin-left: auto;
    margin-right: auto;
    background: rgba(255,255,255,0.98);
    border-radius: 12px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(16,24,32,0.12);
}

/* decorative concentric rings on the right side */
