    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    width: 380px;
    height: 380px;
    pointer-events: none;
}
.login-page .decorative .rings{
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
        radial-gradient(circle at center, rgba(195,15,50,0.06) 50%, transparent 51%),
        radial-gradient(circle at center, rgba(195,15,50,0.03) 30%, transparent 31%),
        radial-gradient(circle at center, rgba(195,15,50,0.02) 15%, transparent 16%);
} */
/* .login-page .decorative .dot{
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 6px 14px rgba(199,27,48,0.28);
} */
.login-page .decorative .dot.one{ right:18%; top:12%; transform: translate(50%,-50%);} 
.login-page .decorative .dot.two{ right:45%; bottom:10%; transform: translate(50%,50%);} 

.btn-danger{ background: var(--primary); border: none; }
.btn-danger:hover{ background: var(--primary-dark); }

@@media (max-width: 900px){
    .login-card{ flex-direction: column; height: auto; }
    .login-visual{ padding: 24px; text-align: center; align-items: center; }
    .login-form{ padding: 24px; }
    .login-form .card{ width: 100%; }
    .login-page .decorative{ display: none; }
}
</style>

<div class="login-page">
    <div class="login-card">

        <!-- LEFT PANEL -->
       <div class="login-visual text-center">

    <!-- LOGO -->
    <img src="data:image/jpeg;base64," 
         alt="Company Logo" 
         style="width:100px; border-radius:10px; margin-bottom:20px;" />

    <!-- COMPANY NAME -->
    <h2 class="fw-bold">Contoso Automotive</h2>

    <!-- OPTIONAL TAGLINE -->
    <p class="mt-2">Secure portal for employees and partners</p>

</div>

        <!-- RIGHT PANEL -->
        <div class="login-form">

            <div class="card">
                <h4 class="text-center mb-3">Login</h4>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="Input.Email" class="form-control" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="Input.Password" class="form-control" type="password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- REMEMBER -->
                    <div class="form-check mb-3">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label"></label>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit" class="btn btn-danger w-100">LOG IN</button>

                    <!-- LINKS -->
                    <div class="text-center mt-3">
                        <a asp-page="./ForgotPassword">Forgot password?</a><br />
                        <a asp-page="./Register">Register</a>
                    </div>
                </form>
            </div>

        </div>

    </div>
    <div class="decorative" aria-hidden="true">
        <div class="rings"></div>
        <div class="dot one"></div>
        <div class="dot two"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // add a body class so footer spacing only applies on this page
        (function(){ document.body.classList.add('login-page-route'); })();
    </script>
}