@{
    ViewData["Title"] = "Services";
}

<h2 class="mb-4">Our Services</h2>

<div class="accordion" id="servicesAccordion">

    <div class="accordion-item">
        <h2 class="accordion-header">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#consulting">
                IT Consulting
            </button>
        </h2>
        <div id="consulting" class="accordion-collapse collapse show">
            <div class="accordion-body">
                We help businesses choose the right technology solutions to improve efficiency.
            </div>
        </div>
    </div>

    <div class="accordion-item">
        <h2 class="accordion-header">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#development">
                Software Development
            </button>
        </h2>
        <div id="development" class="accordion-collapse collapse">
            <div class="accordion-body">
                Our team builds scalable web and mobile applications for modern businesses.
            </div>
        </div>
    </div>

    <div class="accordion-item">
        <h2 class="accordion-header">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#training">
                Professional Training
            </button>
        </h2>
        <div id="training" class="accordion-collapse collapse">
            <div class="accordion-body">
                We provide training programs to help developers learn new technologies.
            </div>
        </div>
    </div>

</div>

