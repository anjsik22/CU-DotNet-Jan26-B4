@{
    ViewData["Title"] = "Home Page";
}


<div class="p-5 mb-5 rounded-3 text-center bg-light">
    <div class="container py-5">

        <h1 class="display-4 fw-bold text-dark">Welcome to TechNova Solutions</h1>

        <p class="lead text-light opacity-75 mt-3 mb-4">
            Delivering innovative software solutions, expert consulting,
            and professional technology training for modern businesses.
        </p>

        <button type="button" class="btn btn-outline-secondary btn-lg me-3" id="liveToastBtn">
            Learn More
        </button>

        <a asp-controller="Contact" asp-action="Index"
           class="btn btn-outline-secondary btn-lg">
            Contact Us
        </a>

    </div>
</div>


<div class="container-fluid px-2 mt-3">
    <div class="row row-cols-1 row-cols-md-3 g-4">

        
        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <img src="data:image/jpeg;base64," class="class=" card-img-top img-fluid"" alt="Services">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Our Services</h5>
                    <p class="card-text">
                        Discover our consulting and technology services designed for businesses.
                    </p>
                    <a asp-controller="Services" asp-action="Index" class="btn btn-primary mt-auto">
                        View Services
                    </a>
                </div>
            </div>
        </div>

        
        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <img src="data:image/jpeg;base64," class="class=" card-img-top img-fluid"" alt="Products">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Our Products</h5>
                    <p class="card-text">
                        Explore our powerful software tools that help businesses grow.
                    </p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-auto">
                        View Products
                    </a>
                </div>
            </div>
        </div>

        
        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-0">
                <img src="data:image/jpeg;base64," class="class=" card-img-top img-fluid"" alt="Contact">
                <div class="card-body">
                    <h5 class="card-title">Contact Us</h5>
                    <p class="card-text">
                        Get in touch with our team for support or collaboration.
                    </p>
                    <a asp-controller="Contact" asp-action="Index" class="btn btn-primary mt-auto">
                        Contact Now
                    </a>
                </div>
            </div>
        </div>
        <div class="toast-container position-fixed bottom-0 end-0 p-3">

            <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">

                <div class="toast-header">
                    <strong class="me-auto">TechNova Solutions</strong>
                    <small>Now</small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
                </div>

                <div class="toast-body">
                    Learn more about our consulting, training, and software solutions in the Services section.
                </div>

            </div>

        </div>

    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const toastTrigger = document.getElementById('liveToastBtn');
        const toastLiveExample = document.getElementById('liveToast');

        if (toastTrigger) {
            toastTrigger.addEventListener('click', function () {
                const toast = new bootstrap.Toast(toastLiveExample);
                toast.show();
            });
        }

    });
</script>