
@{
    ViewData["Title"] = "Checkout";
}

<h1>Checkout</h1>
<div class="container mt-4">
    <h2 class="mb-4">Checkout Summary</h2>

    <div class="card p-4 shadow-sm">

        <p><strong>Base Price:</strong> $@ViewBag.BasePrice</p>
        <p><strong>Promo Code:</strong> @ViewBag.PromoCode</p>

        <h4 class="text-success">
            Final Price: $@ViewBag.FinalPrice
        </h4>

        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary mt-3">
            Back to Products
        </a>

    </div>
</div>

