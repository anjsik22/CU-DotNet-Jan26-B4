
@{
    ViewData["Title"] = "Index";
}

<h1>Product</h1>
<div class="container mt-4">
    <h2 class="mb-4">Product Pricing</h2>

    <div class="card p-4 shadow-sm">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }


        <form asp-action="Index" method="post">
           

            <div class="mb-3">
                <label class="form-label">Base Price</label>
                <input type="number" step="0.01" name="basePrice" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Promo Code</label>
                <select name="promoCode" class="form-control">

                    <option value="">-- Select Promo Code --</option>

                    @if (ViewBag.PromoCode != null && ViewBag.PromoCode.ToString() == "WINTER25")
                    {
                        <option value="WINTER25" selected>WINTER25 (15% OFF)</option>
                    }
                    else
                    {
                        <option value="WINTER25">WINTER25 (15% OFF)</option>
                    }

                    @if (ViewBag.PromoCode != null && ViewBag.PromoCode.ToString() == "FREESHIP")
                    {
                        <option value="FREESHIP" selected>FREESHIP ($5 OFF)</option>
                    }
                    else
                    {
                        <option value="FREESHIP">FREESHIP ($5 OFF)</option>
                    }

                </select>
            </div>

            <button type="submit" class="btn btn-primary">
                Calculate Price
            </button>
        </form>

        

    </div>
</div>

