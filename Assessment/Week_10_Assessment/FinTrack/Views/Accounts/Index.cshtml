@model IEnumerable<FinTrack.Models.Account>

<h2>Accounts</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="accordion" id="accountAccordion">

    @foreach (var account in Model)
    {
        <div class="accordion-item">

            <h2 class="accordion-header" id="heading-@account.Id">
                <button class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#collapse-@account.Id"
                        aria-expanded="false"
                        aria-controls="collapse-@account.Id">

                    <strong>Account No:</strong> @account.AccountNo
                    &nbsp;|&nbsp;
                    <strong>Holder:</strong> @account.AccountHolder
                    &nbsp;|&nbsp;
                    <strong>Balance:</strong> @( (account.Balance + (account.Transactions != null ? account.Transactions.Sum(t => t.Amount) : 0.0)).ToString("C") )

                </button>
            </h2>

            <div id="collapse-@account.Id"
                 class="accordion-collapse collapse"
                 aria-labelledby="heading-@account.Id"
                 data-bs-parent="#accountAccordion">

                <div class="accordion-body">

                    <div class="mb-3">

                        <a asp-action="Edit"
                           asp-route-id="@account.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@account.Id"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@account.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </div>

                    @{
                        var initialBalance = account.Balance;
                        var totalCredit = (account.Transactions != null && account.Transactions.Any()) ? account.Transactions.Where(t => t.Amount >= 0).Sum(t => t.Amount) : 0.0;
                        var totalDebit = (account.Transactions != null && account.Transactions.Any()) ? account.Transactions.Where(t => t.Amount < 0).Sum(t => -t.Amount) : 0.0;
                        var finalBalance = initialBalance + ((account.Transactions != null && account.Transactions.Any()) ? account.Transactions.Sum(t => t.Amount) : 0.0);
                    }

                    <p><strong>Initial Balance:</strong> @initialBalance.ToString("C")</p>

                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Category</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in account.Transactions ?? Enumerable.Empty<FinTrack.Models.Transaction>())
                            {
                                <tr class="@(t.Amount >= 0 ? "table-success" : "table-danger")">
                                    <td>@t.Description</td>
                                    <td>@t.Amount.ToString("C")</td>
                                    <td>@t.Category</td>
                                    <td>@t.Date.ToString("dd-MM-yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="mt-2">
                        <p><strong>Total Credit:</strong> @totalCredit.ToString("C")</p>
                        <p><strong>Total Debited:</strong> @totalDebit.ToString("C")</p>
                        <p><strong>Final Balance:</strong> <strong>@finalBalance.ToString("C")</strong></p>
                    </div>

                </div>
            </div>

        </div>
    }

</div>