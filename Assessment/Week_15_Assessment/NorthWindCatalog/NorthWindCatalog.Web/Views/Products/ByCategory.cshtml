@model List<NorthWindCatalog.Services.DTOs.ProductDto>

<div class="container mt-4">
    <h2>Products</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card m-2 p-3 shadow">
                    <h5>@item.ProductName</h5>

                    <p>💰 Price: @item.UnitPrice</p>
                    <p>📦 Stock: @item.UnitsInStock</p>

                    <p><b>Inventory Value: @item.InventoryValue</b></p>
                </div>
            </div>
        }
    </div>

    <a href="/Categories" class="btn btn-secondary mt-3">Back</a>
</div>
